# Local address used by the NFC bridge.
NFC_READER_HOST=127.0.0.1
NFC_READER_PORT=8765

# Optional. Leave blank to accept the first available PC/SC contactless reader.
# Example: ACS ACR122U
NFC_READER_NAME=

# Comma-separated cashier website origins that may read a scanned UID.
NFC_ALLOWED_ORIGINS=http://localhost:8000
